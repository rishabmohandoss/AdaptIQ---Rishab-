{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".git",
      ".gitignore",
      ".claude",
      "*.md",
      "demo/**",
      "frontend/**",
      "integration/**",
      "perception/**",
      "PRD-details/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
