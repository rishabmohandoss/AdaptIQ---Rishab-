rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /resumes/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid
                          && request.resource.size < 10 * 1024 * 1024
                          && request.resource.contentType.matches('application/pdf|application/.*document.*|text/plain');
    }
  }
}
